<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Alvará - Parauapebas</title>
    <style>
        /* CSS: Melhorando a proporção para telas de computador */
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: #f0f4f8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px; /* Mais espaço nas bordas */
            color: #333;
        }
        
        .cartao {
            background-color: #ffffff;
            padding: 40px; /* Aumentamos o espaçamento interno */
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1); /* Sombra mais bonita */
            width: 100%;
            /* Aqui está o segredo: aumentamos a largura máxima para computadores */
            max-width: 650px; 
        }

        h2 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 30px;
            font-size: 28px;
        }

        /* O CSS Grid vai organizar nossos campos em colunas */
        .grade-formularios {
            display: grid;
            /* No celular (tela pequena), fica 1 coluna. Mas mudaremos isso mais abaixo para PCs! */
            grid-template-columns: 1fr; 
            gap: 15px; /* Espaço entre as caixas */
            margin-bottom: 25px;
        }

        .campo-grupo {
            display: flex;
            flex-direction: column;
        }

        label {
            margin-bottom: 8px;
            font-weight: bold;
            color: #34495e;
            font-size: 14px;
        }

        select, input {
            width: 100%;
            padding: 12px;
            border: 1px solid #bdc3c7;
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 16px;
            background-color: #fdfdfd;
        }
        select:focus, input:focus {
            outline: none;
            border-color: #2980b9;
            box-shadow: 0 0 5px rgba(41, 128, 185, 0.3);
        }

        .botoes-acao {
            display: grid;
            grid-template-columns: 1fr 1fr; /* Dois botões lado a lado sempre */
            gap: 15px;
            margin-bottom: 10px;
        }

        .btn-principal {
            grid-column: span 2; /* O botão de calcular ocupa a largura inteira (as 2 colunas) */
            padding: 16px;
            background-color: #2980b9;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-principal:hover { background-color: #2471a3; }

        .btn-secundario {
            padding: 12px;
            background-color: #95a5a6;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-secundario:hover { background-color: #7f8c8d; }
        
        .btn-imprimir {
            padding: 12px;
            background-color: #f39c12;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            display: none;
        }
        .btn-imprimir:hover { background-color: #d68910; }

        #resultado {
            margin-top: 25px;
            padding: 20px;
            border-radius: 8px;
            display: none;
            font-size: 16px;
            text-align: center;
        }

        .detalhe {
            font-size: 15px;
            color: #555;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px dashed #ccc;
            text-align: left;
            line-height: 1.8;
        }

        /* MEDIA QUERY: A Mágica para Computadores! 
           Se a tela tiver mais de 600px de largura, a grade vira 2 colunas */
        @media (min-width: 600px) {
            .grade-formularios {
                grid-template-columns: 1fr 1fr; /* Duas colunas iguais */
            }
            /* Opcional: fazer alguns campos ocuparem a linha inteira se precisarem */
            .ocupar-linha-inteira {
                grid-column: span 2;
            }
        }

        @media print {
            body { background-color: white; padding: 0; }
            .cartao { box-shadow: none; max-width: 100%; border: none; }
            button, .grade-formularios { display: none; }
            h2, #resultado { display: block !important; }
            .cartao::after { 
                content: "Simulação de Alvará - Prefeitura de Parauapebas"; 
                display: block; margin-top: 50px; text-align: center; font-weight: bold; 
            }
        }
    </style>
</head>
<body>

<div class="cartao">
    <h2>Simulador de Alvará Padrão</h2>
    
    <!-- HTML: Usando a nova estrutura de grade (Grid) -->
    <div class="grade-formularios">
        
        <div class="campo-grupo">
            <label for="anoSelecionado">Ano de Referência:</label>
            <select id="anoSelecionado" onchange="atualizarValorUFM()">
                <option value="19.30">2026 (R$ 19,30)</option>
                <option value="18.50">2025 (R$ 18,50)</option>
                <option value="17.71">2024 (R$ 17,71)</option>
                <option value="16.92">2023 (R$ 16,92)</option>
                <option value="10.42">2020 (R$ 10,42)</option>
                <option value="manual">Digitar Manualmente...</option>
            </select>
        </div>

        <div class="campo-grupo">
            <label for="ufmValor">Valor da UFM (R$):</label>
            <input type="number" id="ufmValor" value="19.30" step="0.01">
        </div>

        <div class="campo-grupo ocupar-linha-inteira">
            <label for="metragem">Área do Estabelecimento (m²):</label>
            <input type="number" id="metragem" placeholder="Ex: 120.5">
        </div>

        <div class="campo-grupo">
            <label for="mesCriacao">Mês de Abertura:</label>
            <select id="mesCriacao">
                <option value="1">Janeiro (Integral)</option>
                <option value="2">Fevereiro (11/12)</option>
                <option value="3">Março (10/12)</option>
                <option value="4">Abril (9/12)</option>
                <option value="5">Maio (8/12)</option>
                <option value="6">Junho (7/12)</option>
                <option value="7">Julho (6/12)</option>
                <option value="8">Agosto (5/12)</option>
                <option value="9">Setembro (4/12)</option>
                <option value="10">Outubro (3/12)</option>
                <option value="11">Novembro (2/12)</option>
                <option value="12">Dezembro (1/12)</option>
            </select>
        </div>

        <div class="campo-grupo">
            <label for="horarioEspecial">Horário Especial:</label>
            <select id="horarioEspecial">
                <option value="0">Sem acréscimo (+0%)</option>
                <option value="10">1 Hipótese (+10%)</option>
                <option value="20">2 Hipóteses (+20%)</option>
                <option value="30">3+ Hipóteses (+30%)</option>
            </select>
        </div>

    </div> <!-- Fim da Grade -->

    <div class="botoes-acao">
        <button class="btn-principal" onclick="calcularTaxa()">Calcular Valor Final</button>
        <button class="btn-secundario" onclick="limparCampos()">Limpar Tudo</button>
        <button class="btn-imprimir" id="btnImprimir" onclick="imprimirRecibo()">Imprimir PDF</button>
    </div>

    <div id="resultado"></div>
</div>

<script>
    function atualizarValorUFM() {
        let selectAno = document.getElementById('anoSelecionado');
        let inputUfm = document.getElementById('ufmValor');
        if (selectAno.value === "manual") {
            inputUfm.value = "";
            inputUfm.focus();
        } else {
            inputUfm.value = selectAno.value;
        }
    }

    function calcularTaxa() {
        let ufmReais = parseFloat(document.getElementById('ufmValor').value);
        let area = parseFloat(document.getElementById('metragem').value);
        let mes = parseInt(document.getElementById('mesCriacao').value);
        let percentualEspecial = parseInt(document.getElementById('horarioEspecial').value);
        let resultadoDiv = document.getElementById('resultado');
        let btnImprimir = document.getElementById('btnImprimir');

        if (isNaN(ufmReais) || isNaN(area) || area <= 0) {
            resultadoDiv.innerHTML = "Por favor, preencha a área corretamente.";
            resultadoDiv.style.display = "block";
            resultadoDiv.style.backgroundColor = "#fadbd8";
            resultadoDiv.style.borderLeft = "5px solid #e74c3c";
            btnImprimir.style.display = "none";
            return;
        }

        let quantidadeUFM = 0;
        if (area <= 50) { quantidadeUFM = 10; } 
        else if (area <= 100) { quantidadeUFM = 20; } 
        else if (area <= 150) { quantidadeUFM = 30; } 
        else if (area <= 270) { quantidadeUFM = 50; } 
        else if (area <= 500) { quantidadeUFM = 100; } 
        else if (area <= 5000) { quantidadeUFM = 130; } 
        else if (area <= 10000) { quantidadeUFM = 150; } 
        else {
            let areaExcedente = area - 10000;
            let blocosExcedentes = Math.ceil(areaExcedente / 50);
            quantidadeUFM = 170 + (blocosExcedentes * 4);
            if (quantidadeUFM > 100000) { quantidadeUFM = 100000; }
        }

        let valorCheio = quantidadeUFM * ufmReais;
        let mesesTrabalhados = 13 - mes;
        let valorProporcional = valorCheio * (mesesTrabalhados / 12);
        let valorAcrescimo = valorProporcional * (percentualEspecial / 100);
        let valorFinal = valorProporcional + valorAcrescimo;

        resultadoDiv.innerHTML = 
            "Valor Final a pagar: <br><strong style='font-size: 28px; color: #27ae60;'>" + 
            valorFinal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) + 
            "</strong>" +
            "<div class='detalhe'>" +
            "<strong>Detalhes do Cálculo:</strong><br>" +
            "• Área Referência: " + area + "m² (" + quantidadeUFM + " UFM)<br>" +
            "• Base Anual: " + valorCheio.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) + "<br>" +
            "• Proporcionalidade (" + mesesTrabalhados + "/12): " + valorProporcional.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) + "<br>" +
            "• Acréscimo (" + percentualEspecial + "%): " + valorAcrescimo.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) +
            "</div>";
        
        resultadoDiv.style.display = "block";
        resultadoDiv.style.backgroundColor = "#e8f8f5";
        resultadoDiv.style.borderLeft = "6px solid #27ae60";
        btnImprimir.style.display = "block";
    }

    function limparCampos() {
        document.getElementById('anoSelecionado').value = "19.30";
        document.getElementById('ufmValor').value = "19.30";
        document.getElementById('metragem').value = "";
        document.getElementById('mesCriacao').value = "1";
        document.getElementById('horarioEspecial').value = "0";
        document.getElementById('resultado').style.display = "none";
        document.getElementById('btnImprimir').style.display = "none";
    }

    function imprimirRecibo() { window.print(); }
</script>

</body>
</html>
